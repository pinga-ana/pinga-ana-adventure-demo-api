# Copie para .env local ou defina só no painel da Vercel (Settings → Environment Variables).
# Substitua USER e PASSWORD; a base pinga_ana é criada ao usar no path (ou ajuste MONGODB_DB).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.9qmia0k.mongodb.net/pinga_ana?retryWrites=true&w=majority&appName=Cluster0
# Opcional: nome da base se não estiver no URI (default pinga_ana)
# MONGODB_DB=pinga_ana
